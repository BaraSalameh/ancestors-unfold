POSTGRES_DB=ancestors_unfold
POSTGRES_USER=ancestors
POSTGRES_PASSWORD=replace-with-a-long-random-development-password
DATABASE_URL=postgres://ancestors:replace-with-the-same-password@localhost:5432/ancestors_unfold
DATABASE_SSL=false
SESSION_COOKIE_SECURE=false
SESSION_IDLE_HOURS=24
SESSION_ABSOLUTE_DAYS=30
PUBLIC_ORIGIN=http://localhost:3000
# Register PUBLIC_ORIGIN/api/auth/google/callback as an authorized Google redirect URI.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
TRUST_PROXY=false
MAX_REQUEST_BYTES=1000000
AUTH_TOKEN_DELIVERY=console
# Development Gmail SMTP example. Use a Google app password, never the account password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=noreplyfamilytree1@gmail.com
SMTP_PASS=
# Set AUTH_TOKEN_DELIVERY=resend in production and verify EMAIL_FROM's domain in Resend.
RESEND_API_KEY=
EMAIL_FROM="Ancestors Unfold <noreplyfamilytree1@gmail.com>"
# Keep this secret stable; changing it invalidates outstanding email codes.
EMAIL_CODE_SECRET=replace-with-a-long-random-secret
REQUIRED_MIGRATIONS=4
